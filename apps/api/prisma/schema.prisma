generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

model User {
  id        String   @id
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id              String         @id @default(cuid())
  name            String
  workspaceScope  ScopeType      @default(DEFAULT_WORKSPACE)
  customScopePath String?
  permissionMode  String         @default("ASK")
  memoryScope     MemoryScope    @default(GLOBAL_AND_PROJECT)
  defaultBackend  BackendType    @default(E2B)
  defaultProvider String?
  defaultModel    String?
  browserMode     BrowserMode    @default(SEPARATE_PROFILE)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  conversations   Conversation[]

  @@index([createdAt])
}

model ProviderConfig {
  id            String   @id
  enabled       Boolean  @default(false)
  primaryModel  String
  fallbackOrder Int
  authMode      String   @default("apiKey")
  baseURL       String?
  modelName     String?
  updatedAt     DateTime @default(now()) @updatedAt
}

model SafetySettings {
  id             String   @id @default("global")
  trustedDomains Json     @default("[]")
  updatedAt      DateTime @default(now()) @updatedAt
}

model ExecutionSettings {
  id             String   @id @default("global")
  defaultBackend String   @default("e2b")
  cleanupPolicy  String   @default("keep-all")
  updatedAt      DateTime @default(now()) @updatedAt
}

model BrowserSettings {
  id        String   @id @default("global")
  mode      String   @default("separate-profile")
  updatedAt DateTime @default(now()) @updatedAt
}

model MemorySettings {
  id                           String      @id @default("global")
  provider                     String      @default("self-hosted")
  defaultScopeForNewProjects   MemoryScope @default(GLOBAL_AND_PROJECT)
  cloudBaseURL                 String?
  selfHostedBaseURL            String      @default("http://127.0.0.1:8000")
  updatedAt                    DateTime    @default(now()) @updatedAt
}

enum TaskStatus {
  RUNNING
  WAITING
  STOPPED
  ERROR
  PAUSED
}

enum ScopeType {
  DEFAULT_WORKSPACE
  CUSTOM_FOLDER
  DESKTOP
  FULL_ACCESS
}

enum BackendType {
  E2B
  LOCAL
}

enum BrowserMode {
  SEPARATE_PROFILE
  ACTUAL_CHROME
}

enum MemoryScope {
  GLOBAL_AND_PROJECT
  PROJECT_ONLY
  NONE
}

enum IntegrationConnectorId {
  GMAIL
  SLACK
  NOTION
  GOOGLE_DRIVE
  GITHUB
  GOOGLE_CALENDAR
  CLOUDFLARE
  VERCEL
  LINEAR
  GOOGLE_SHEETS
  GOOGLE_DOCS
  ZAPIER
  OBSIDIAN
}

enum IntegrationConnectionStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
  EXPIRED
  REVOKED
  RATE_LIMITED
  ERROR
}

model NangoSettings {
  id               String   @id @default("global")
  configured       Boolean  @default(false)
  host             String   @default("https://api.nango.dev")
  lastErrorCode    String?
  lastErrorMessage String?
  lastValidatedAt  DateTime?
  secretKeyRef     String?
  updatedAt        DateTime @default(now()) @updatedAt
}

model IntegrationConnectorSettings {
  id                    String                 @id @default(cuid())
  connectorId            IntegrationConnectorId @unique
  lastErrorCode          String?
  lastErrorMessage       String?
  lastValidatedAt        DateTime?
  nangoIntegrationId     String?
  nangoProviderId        String?
  oauthClientId          String?
  oauthClientSecretRef   String?
  redirectUri            String?
  requiredScopes         Json                   @default("[]")
  setupStatus            String                 @default("missing_credentials")
  updatedAt              DateTime               @default(now()) @updatedAt
}

model Integration {
  id                String                      @id @default(cuid())
  userId            String
  connectorId       IntegrationConnectorId
  nangoIntegrationId String?
  nangoConnectionId String?
  accountAlias      String
  accountLabel      String?
  status            IntegrationConnectionStatus @default(DISCONNECTED)
  scopes            Json                        @default("[]")
  defaultAccount    Boolean                     @default(false)
  memoryScope       MemoryScope                 @default(NONE)
  lastUsedAt        DateTime?
  lastHealthCheckAt DateTime?
  lastErrorCode     String?
  lastErrorMessage  String?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  @@index([userId, connectorId])
  @@index([userId, status])
  @@unique([userId, connectorId, accountAlias])
}

model Conversation {
  id        String     @id @default(cuid())
  projectId String
  title     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages  Message[]
  agentRuns AgentRun[]

  @@index([projectId, updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  memoryEnabled  Boolean?
  agentRunId     String?
  providerId     String?
  modelName      String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agentRun       AgentRun?    @relation(fields: [agentRunId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([agentRunId])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

model AgentRun {
  id             String         @id @default(cuid())
  conversationId String
  status         AgentRunStatus @default(RUNNING)
  goal           String
  result         String?
  toolCalls      Json           @default("[]")
  costUsd        Decimal?       @db.Decimal(10, 4)
  backend        BackendType    @default(E2B)
  providerId     String?
  modelName      String?
  sandboxId      String?
  startedAt      DateTime       @default(now())
  completedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  conversation   Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  messages       Message[]
  checkpoints    AgentRunCheckpoint[]
  trajectory     AgentRunTrajectory?
  sharedMemoryNamespaces SharedMemoryNamespace[]

  @@index([conversationId, startedAt])
  @@index([status])
}

enum AgentRunStatus {
  RUNNING
  WAITING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

model AgentRunTrajectory {
  id             String             @id @default(cuid())
  agentRunId     String             @unique
  agentRun       AgentRun           @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
  steps          Json               @default("[]")
  outcome        TrajectoryOutcome  @default(RUNNING)
  outcomeReason  String?
  outcomeMetrics Json               @default("{}")
  goal           String             @default("")
  goalEmbedding  Bytes?
  templateId     String?
  template       TrajectoryTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdAt      DateTime           @default(now())
  completedAt    DateTime?

  @@index([outcome, createdAt])
  @@index([templateId])
}

enum TrajectoryOutcome {
  RUNNING
  SUCCEEDED
  FAILED
  ABANDONED
  CANCELLED
}

model TrajectoryTemplate {
  id             String               @id @default(cuid())
  name           String
  pattern        Json
  goalEmbedding  Bytes
  successRate    Float
  usageCount     Int                  @default(0)
  createdFromIds String[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  trajectories   AgentRunTrajectory[]

  @@index([updatedAt])
}

model AgentRunCheckpoint {
  id         String   @id @default(cuid())
  agentRunId String
  agentRun   AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
  stepIndex  Int
  state      Json
  sandboxRef String?
  createdAt  DateTime @default(now())

  @@index([agentRunId, stepIndex])
}

model SharedMemoryNamespace {
  id          String   @id @default(cuid())
  parentRunId String
  parentRun   AgentRun @relation(fields: [parentRunId], references: [id], onDelete: Cascade)
  entries     Json     @default("{}")
  lockedKeys  String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([parentRunId])
}

model ApprovalRequest {
  id          String    @id @default(cuid())
  taskId      String
  type        String
  payload     Json
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  respondedAt DateTime?

  @@index([taskId, status])
}
