{
  "name": "@handle/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "dotenv -e ../../.env -- next build",
    "dev": "dotenv -e ../../.env -- next dev --hostname 127.0.0.1 --port 3000",
    "lint": "eslint .",
    "start": "dotenv -e ../../.env -- next start",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.2.9",
    "@handle/design-refs": "workspace:*",
    "@handle/design-tokens": "workspace:*",
    "@handle/shared": "workspace:*",
    "class-variance-authority": "~0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "next": "^15.5.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "autoprefixer": "^10.5.0",
    "dotenv-cli": "^11.0.0",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.19"
  }
}
