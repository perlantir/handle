generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

model User {
  id        String   @id
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id                   String                       @id @default(cuid())
  name                 String
  workspaceScope       ScopeType                    @default(DEFAULT_WORKSPACE)
  customScopePath      String?
  permissionMode       String                       @default("ASK")
  memoryScope          MemoryScope                  @default(GLOBAL_AND_PROJECT)
  defaultBackend       BackendType                  @default(E2B)
  defaultProvider      String?
  defaultModel         String?
  browserMode          BrowserMode                  @default(SEPARATE_PROFILE)
  criticEnabled        Boolean                      @default(false)
  criticModel          String?
  criticScope          String                       @default("risky-only")
  criticMaxRevisions   Int                          @default(3)
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
  conversations        Conversation[]
  notificationSettings ProjectNotificationSettings?
  searchSettings       ProjectSearchSettings?
  criticReviews        CriticReview[]

  @@index([createdAt])
}

model ProviderConfig {
  id            String   @id
  enabled       Boolean  @default(false)
  primaryModel  String
  fallbackOrder Int
  authMode      String   @default("apiKey")
  baseURL       String?
  modelName     String?
  updatedAt     DateTime @default(now()) @updatedAt
}

model SafetySettings {
  id             String   @id @default("global")
  trustedDomains Json     @default("[]")
  updatedAt      DateTime @default(now()) @updatedAt
}

model ExecutionSettings {
  id             String   @id @default("global")
  defaultBackend String   @default("e2b")
  cleanupPolicy  String   @default("keep-all")
  updatedAt      DateTime @default(now()) @updatedAt
}

model BrowserSettings {
  id        String   @id @default("global")
  mode      String   @default("separate-profile")
  updatedAt DateTime @default(now()) @updatedAt
}

model MemorySettings {
  id                         String      @id @default("global")
  provider                   String      @default("self-hosted")
  defaultScopeForNewProjects MemoryScope @default(GLOBAL_AND_PROJECT)
  cloudBaseURL               String?
  selfHostedBaseURL          String      @default("http://127.0.0.1:8000")
  updatedAt                  DateTime    @default(now()) @updatedAt
}

enum TaskStatus {
  RUNNING
  WAITING
  STOPPED
  ERROR
  PAUSED
}

enum ScopeType {
  DEFAULT_WORKSPACE
  CUSTOM_FOLDER
  DESKTOP
  FULL_ACCESS
}

enum BackendType {
  E2B
  LOCAL
}

enum BrowserMode {
  SEPARATE_PROFILE
  ACTUAL_CHROME
}

enum MemoryScope {
  GLOBAL_AND_PROJECT
  PROJECT_ONLY
  NONE
}

enum SearchProviderId {
  TAVILY
  SERPER
  BRAVE
}

enum IntegrationConnectorId {
  GMAIL
  SLACK
  NOTION
  GOOGLE_DRIVE
  GITHUB
  GOOGLE_CALENDAR
  CLOUDFLARE
  VERCEL
  LINEAR
  GOOGLE_SHEETS
  GOOGLE_DOCS
  ZAPIER
  OBSIDIAN
}

enum IntegrationConnectionStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
  EXPIRED
  REVOKED
  RATE_LIMITED
  ERROR
}

model TemporalSettings {
  id               String    @id @default("global")
  enabled          Boolean   @default(true)
  address          String    @default("127.0.0.1:7233")
  namespace        String    @default("default")
  taskQueue        String    @default("handle-agent-runs")
  lastHealthStatus String    @default("unknown")
  lastErrorCode    String?
  lastErrorMessage String?
  lastCheckedAt    DateTime?
  updatedAt        DateTime  @default(now()) @updatedAt
}

model NotificationSettings {
  id             String   @id @default("global")
  emailEnabled   Boolean  @default(false)
  emailRecipient String?
  slackEnabled   Boolean  @default(false)
  slackChannelId String?
  webhookEnabled Boolean  @default(false)
  webhookUrl     String?
  eventTypes     Json     @default("[\"TASK_COMPLETED\",\"TASK_FAILED\",\"APPROVAL_NEEDED\",\"CRITIC_FLAGGED\"]")
  updatedAt      DateTime @default(now()) @updatedAt
}

model ProjectNotificationSettings {
  id             String   @id @default(cuid())
  projectId      String   @unique
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inheritGlobal  Boolean  @default(true)
  emailEnabled   Boolean?
  emailRecipient String?
  slackEnabled   Boolean?
  slackChannelId String?
  webhookEnabled Boolean?
  webhookUrl     String?
  eventTypes     Json?
  updatedAt      DateTime @default(now()) @updatedAt
}

model NotificationDelivery {
  id           String                @id @default(cuid())
  userId       String
  projectId    String?
  agentRunId   String?
  eventType    NotificationEventType
  channel      NotificationChannel
  recipient    String
  payload      Json                  @default("{}")
  status       NotificationStatus    @default(PENDING)
  errorCode    String?
  errorMessage String?
  dispatchedAt DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([userId, createdAt])
  @@index([agentRunId])
  @@index([status])
}

model Workflow {
  id                 String        @id @default(cuid())
  userId             String
  name               String
  enabled            Boolean       @default(false)
  triggerConnectorId String
  triggerEventType   String
  triggerFilter      Json          @default("{}")
  actions            Json          @default("[]")
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  runs               WorkflowRun[]

  @@index([userId, enabled])
  @@index([triggerConnectorId, triggerEventType])
}

model WorkflowRun {
  id           String    @id @default(cuid())
  workflowId   String
  workflow     Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  status       String    @default("QUEUED")
  eventPayload Json      @default("{}")
  error        String?
  actionLogId  String?
  triggeredAt  DateTime  @default(now())
  completedAt  DateTime?

  @@index([workflowId, triggeredAt])
  @@index([status])
}

model SearchProviderConfig {
  id                 String           @id @default(cuid())
  userId             String
  providerId         SearchProviderId
  enabled            Boolean          @default(false)
  keychainAlias      String?
  rateLimitPerMinute Int?
  memoryScope        MemoryScope      @default(NONE)
  lastTestedAt       DateTime?
  lastErrorCode      String?
  lastErrorMessage   String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@unique([userId, providerId])
  @@index([userId, enabled])
}

model ProjectSearchSettings {
  id              String            @id @default(cuid())
  projectId       String            @unique
  project         Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  defaultProvider SearchProviderId?
  fallbackOrder   Json              @default("[\"TAVILY\",\"SERPER\",\"BRAVE\",\"BUILT_IN\"]")
  memoryScope     MemoryScope       @default(NONE)
  updatedAt       DateTime          @default(now()) @updatedAt
}

enum NotificationEventType {
  TASK_COMPLETED
  TASK_FAILED
  APPROVAL_NEEDED
  CRITIC_FLAGGED
}

enum NotificationChannel {
  EMAIL
  SLACK
  WEBHOOK
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model NangoSettings {
  id               String    @id @default("global")
  configured       Boolean   @default(false)
  host             String    @default("https://api.nango.dev")
  lastErrorCode    String?
  lastErrorMessage String?
  lastValidatedAt  DateTime?
  secretKeyRef     String?
  updatedAt        DateTime  @default(now()) @updatedAt
}

model IntegrationConnectorSettings {
  id                   String                 @id @default(cuid())
  connectorId          IntegrationConnectorId @unique
  lastErrorCode        String?
  lastErrorMessage     String?
  lastValidatedAt      DateTime?
  nangoIntegrationId   String?
  nangoProviderId      String?
  oauthClientId        String?
  oauthClientSecretRef String?
  redirectUri          String?
  requiredScopes       Json                   @default("[]")
  setupStatus          String                 @default("missing_credentials")
  updatedAt            DateTime               @default(now()) @updatedAt
}

model Integration {
  id                 String                      @id @default(cuid())
  userId             String
  connectorId        IntegrationConnectorId
  nangoIntegrationId String?
  nangoConnectionId  String?
  accountAlias       String
  accountLabel       String?
  status             IntegrationConnectionStatus @default(DISCONNECTED)
  scopes             Json                        @default("[]")
  defaultAccount     Boolean                     @default(false)
  memoryScope        MemoryScope                 @default(NONE)
  metadata           Json                        @default("{}")
  lastUsedAt         DateTime?
  lastHealthCheckAt  DateTime?
  lastErrorCode      String?
  lastErrorMessage   String?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  @@unique([userId, connectorId, accountAlias])
  @@index([userId, connectorId])
  @@index([userId, status])
}

model Conversation {
  id        String     @id @default(cuid())
  projectId String
  title     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages  Message[]
  agentRuns AgentRun[]

  @@index([projectId, updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  memoryEnabled  Boolean?
  agentRunId     String?
  providerId     String?
  modelName      String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agentRun       AgentRun?    @relation(fields: [agentRunId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([agentRunId])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

model AgentRun {
  id                     String                  @id @default(cuid())
  conversationId         String
  userId                 String?
  status                 AgentRunStatus          @default(RUNNING)
  goal                   String
  result                 String?
  toolCalls              Json                    @default("[]")
  costUsd                Decimal?                @db.Decimal(10, 4)
  backend                BackendType             @default(E2B)
  providerId             String?
  modelName              String?
  sandboxId              String?
  workflowId             String?                 @unique
  workflowRunId          String?
  workflowStatus         String?
  queuedAt               DateTime?
  lastHeartbeatAt        DateTime?
  lastNotifiedAt         DateTime?
  asyncMode              Boolean                 @default(false)
  startedAt              DateTime                @default(now())
  completedAt            DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  conversation           Conversation            @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  messages               Message[]
  checkpoints            AgentRunCheckpoint[]
  trajectory             AgentRunTrajectory?
  sharedMemoryNamespaces SharedMemoryNamespace[]
  criticReviews          CriticReview[]

  @@index([conversationId, startedAt])
  @@index([status])
  @@index([userId])
  @@index([workflowRunId])
}

model CriticReview {
  id                String   @id @default(cuid())
  agentRunId        String
  agentRun          AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
  projectId         String?
  project           Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  interventionPoint String
  verdict           String
  reasoning         String
  metadata          Json     @default("{}")
  createdAt         DateTime @default(now())

  @@index([agentRunId, createdAt])
  @@index([projectId, createdAt])
}

enum AgentRunStatus {
  QUEUED
  RUNNING
  WAITING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

model AgentRunTrajectory {
  id             String              @id @default(cuid())
  agentRunId     String              @unique
  agentRun       AgentRun            @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
  steps          Json                @default("[]")
  outcome        TrajectoryOutcome   @default(RUNNING)
  outcomeReason  String?
  outcomeMetrics Json                @default("{}")
  goal           String              @default("")
  goalEmbedding  Bytes?
  templateId     String?
  template       TrajectoryTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdAt      DateTime            @default(now())
  completedAt    DateTime?

  @@index([outcome, createdAt])
  @@index([templateId])
}

enum TrajectoryOutcome {
  RUNNING
  SUCCEEDED
  FAILED
  ABANDONED
  CANCELLED
}

model TrajectoryTemplate {
  id             String               @id @default(cuid())
  name           String
  pattern        Json
  goalEmbedding  Bytes
  successRate    Float
  usageCount     Int                  @default(0)
  createdFromIds String[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  trajectories   AgentRunTrajectory[]

  @@index([updatedAt])
}

model AgentRunCheckpoint {
  id         String   @id @default(cuid())
  agentRunId String
  agentRun   AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
  stepIndex  Int
  state      Json
  sandboxRef String?
  createdAt  DateTime @default(now())

  @@index([agentRunId, stepIndex])
}

model SharedMemoryNamespace {
  id          String   @id @default(cuid())
  parentRunId String
  parentRun   AgentRun @relation(fields: [parentRunId], references: [id], onDelete: Cascade)
  entries     Json     @default("{}")
  lockedKeys  String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([parentRunId])
}

model ApprovalRequest {
  id          String    @id @default(cuid())
  taskId      String
  type        String
  payload     Json
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  respondedAt DateTime?

  @@index([taskId, status])
}
