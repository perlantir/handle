generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

model User {
  id        String   @id
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id              String         @id @default(cuid())
  name            String
  workspaceScope  ScopeType      @default(DEFAULT_WORKSPACE)
  customScopePath String?
  defaultBackend  BackendType    @default(E2B)
  defaultProvider String?
  defaultModel    String?
  browserMode     BrowserMode    @default(SEPARATE_PROFILE)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  conversations   Conversation[]

  @@index([createdAt])
}

model ProviderConfig {
  id            String   @id
  enabled       Boolean  @default(false)
  primaryModel  String
  fallbackOrder Int
  authMode      String   @default("apiKey")
  baseURL       String?
  modelName     String?
  updatedAt     DateTime @default(now()) @updatedAt
}

model SafetySettings {
  id             String   @id @default("global")
  trustedDomains Json     @default("[]")
  updatedAt      DateTime @default(now()) @updatedAt
}

model ExecutionSettings {
  id             String   @id @default("global")
  defaultBackend String   @default("e2b")
  cleanupPolicy  String   @default("keep-all")
  updatedAt      DateTime @default(now()) @updatedAt
}

model BrowserSettings {
  id        String   @id @default("global")
  mode      String   @default("separate-profile")
  updatedAt DateTime @default(now()) @updatedAt
}

enum TaskStatus {
  RUNNING
  WAITING
  STOPPED
  ERROR
  PAUSED
}

enum ScopeType {
  DEFAULT_WORKSPACE
  CUSTOM_FOLDER
  DESKTOP
  FULL_ACCESS
}

enum BackendType {
  E2B
  LOCAL
}

enum BrowserMode {
  SEPARATE_PROFILE
  ACTUAL_CHROME
}

model Conversation {
  id        String     @id @default(cuid())
  projectId String
  title     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages  Message[]
  agentRuns AgentRun[]

  @@index([projectId, updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  agentRunId     String?
  providerId     String?
  modelName      String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agentRun       AgentRun?    @relation(fields: [agentRunId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([agentRunId])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

model AgentRun {
  id             String         @id @default(cuid())
  conversationId String
  status         AgentRunStatus @default(RUNNING)
  goal           String
  result         String?
  toolCalls      Json           @default("[]")
  costUsd        Decimal?       @db.Decimal(10, 4)
  backend        BackendType    @default(E2B)
  providerId     String?
  modelName      String?
  sandboxId      String?
  startedAt      DateTime       @default(now())
  completedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  conversation   Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@index([conversationId, startedAt])
  @@index([status])
}

enum AgentRunStatus {
  RUNNING
  WAITING
  COMPLETED
  FAILED
  CANCELLED
}

model ApprovalRequest {
  id          String    @id @default(cuid())
  taskId      String
  type        String
  payload     Json
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  respondedAt DateTime?

  @@index([taskId, status])
}
