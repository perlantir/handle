{
  "name": "handle",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "turbo lint",
    "memory:up": "mkdir -p ${DOCKER_CONFIG:-/tmp/handle-docker-config}/cli-plugins && ln -sf $HOME/.docker/cli-plugins/docker-compose ${DOCKER_CONFIG:-/tmp/handle-docker-config}/cli-plugins/docker-compose && DOCKER_CONFIG=${DOCKER_CONFIG:-/tmp/handle-docker-config} docker compose -f docker-compose.zep.yaml up -d",
    "memory:down": "mkdir -p ${DOCKER_CONFIG:-/tmp/handle-docker-config}/cli-plugins && ln -sf $HOME/.docker/cli-plugins/docker-compose ${DOCKER_CONFIG:-/tmp/handle-docker-config}/cli-plugins/docker-compose && DOCKER_CONFIG=${DOCKER_CONFIG:-/tmp/handle-docker-config} docker compose -f docker-compose.zep.yaml down",
    "memory:logs": "mkdir -p ${DOCKER_CONFIG:-/tmp/handle-docker-config}/cli-plugins && ln -sf $HOME/.docker/cli-plugins/docker-compose ${DOCKER_CONFIG:-/tmp/handle-docker-config}/cli-plugins/docker-compose && DOCKER_CONFIG=${DOCKER_CONFIG:-/tmp/handle-docker-config} docker compose -f docker-compose.zep.yaml logs -f zep zep-graphiti",
    "smoke:e2e-canonical": "node scripts/smoke/e2e-task.mjs --canonical",
    "smoke:e2e-providers": "node scripts/smoke/e2e-providers.mjs",
    "smoke:e2e-task": "node scripts/smoke/e2e-task.mjs",
    "smoke:approval-flow": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/approval-flow.mjs",
    "smoke:approval-modal-types": "playwright test --config apps/web/playwright.config.ts apps/web/playwright/approval-modal-types.spec.ts",
    "smoke:agent-run-cancel": "node scripts/smoke/agent-run-cancel.mjs",
    "smoke:actual-chrome-connection-error": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/actual-chrome-connection-error.mjs",
    "smoke:browser-tools": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/browser-tools.mjs",
    "smoke:conversation-multi-turn": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/conversation-multi-turn.mjs",
    "smoke:conversation-history-persistence": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/conversation-history-persistence.mjs",
    "smoke:computer-use-agent": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/computer-use-agent.mjs",
    "smoke:desktop-sandbox": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/desktop-sandbox.mjs",
    "smoke:computer-use-task": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/computer-use-task.mjs",
    "smoke:local-backend-basic": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/local-backend-basic.mjs",
    "smoke:local-backend-audit-log": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/local-backend-audit-log.mjs",
    "smoke:local-backend-safety": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/local-backend-safety.mjs",
    "smoke:local-agent-integration": "node scripts/smoke/local-agent-integration.mjs",
    "smoke:local-browser-actual-chrome": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/local-browser-actual-chrome.mjs",
    "smoke:local-browser-separate-profile": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/local-browser-separate-profile.mjs",
    "smoke:local-rate-limit": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/local-rate-limit.mjs",
    "smoke:rate-limit-error-surfaces": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/rate-limit-error-surfaces.mjs",
    "smoke:model-switching": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/model-switching.mjs",
    "smoke:message-interrupt": "node scripts/smoke/message-interrupt.mjs",
    "smoke:memory-recall": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/memory-recall.mjs",
    "smoke:mid-conversation-backend-switch": "node scripts/smoke/mid-conversation-backend-switch.mjs",
    "smoke:project-creation-rename": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/project-creation-rename.mjs",
    "smoke:projects-crud": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/projects-crud.mjs",
    "smoke:screenshot-stream": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/screenshot-stream.mjs",
    "smoke:scope-custom-folder": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/scope-custom-folder.mjs",
    "smoke:scope-default-workspace": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/scope-default-workspace.mjs",
    "smoke:scope-forbidden-still-denied": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/scope-forbidden-still-denied.mjs",
    "smoke:scope-full-access": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/scope-full-access.mjs",
    "smoke:scope-mid-project-change": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/scope-mid-project-change.mjs",
    "smoke:settings-api-proxy": "node scripts/smoke/settings-api-proxy.mjs",
    "smoke:settings-browser-ui": "playwright test --config apps/web/playwright.config.ts apps/web/playwright/settings-browser.spec.ts",
    "smoke:settings-execution-ui": "playwright test --config apps/web/playwright.config.ts apps/web/playwright/settings-execution.spec.ts",
    "smoke:settings-providers-ui": "playwright test --config apps/web/playwright.config.ts --workers=1",
    "smoke:workspace-backend-pill": "playwright test --config apps/web/playwright.config.ts apps/web/playwright/workspace-backend-pill.spec.ts",
    "smoke:workspace-ui-regression": "playwright test --config apps/web/playwright.config.ts apps/web/playwright/workspace-ui-regression.spec.ts",
    "smoke:trivial-question-no-tools": "node scripts/smoke/trivial-question-no-tools.mjs",
    "smoke:web-signin": "node scripts/smoke/web-signin.mjs",
    "smoke:zep-client-connect": "pnpm --filter @handle/api exec tsx ../../scripts/smoke/zep-client-connect.mjs",
    "smoke:zep-self-hosted-up": "node scripts/smoke/zep-self-hosted-up.mjs",
    "test": "pnpm -r --if-present test",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.19.39",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
