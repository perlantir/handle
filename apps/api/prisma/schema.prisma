generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

model User {
  id        String   @id
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id                   String                       @id @default(cuid())
  name                 String
  workspaceScope       ScopeType                    @default(DEFAULT_WORKSPACE)
  customScopePath      String?
  permissionMode       String                       @default("ASK")
  memoryScope          MemoryScope                  @default(GLOBAL_AND_PROJECT)
  defaultBackend       BackendType                  @default(E2B)
  defaultProvider      String?
  defaultModel         String?
  browserMode          BrowserMode                  @default(SEPARATE_PROFILE)
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
  conversations        Conversation[]
  notificationSettings ProjectNotificationSettings?

  @@index([createdAt])
}

model ProviderConfig {
  id            String   @id
  enabled       Boolean  @default(false)
  primaryModel  String
  fallbackOrder Int
  authMode      String   @default("apiKey")
  baseURL       String?
  modelName     String?
  updatedAt     DateTime @default(now()) @updatedAt
}

model SafetySettings {
  id             String   @id @default("global")
  trustedDomains Json     @default("[]")
  updatedAt      DateTime @default(now()) @updatedAt
}

model ExecutionSettings {
  id             String   @id @default("global")
  defaultBackend String   @default("e2b")
  cleanupPolicy  String   @default("keep-all")
  updatedAt      DateTime @default(now()) @updatedAt
}

model BrowserSettings {
  id        String   @id @default("global")
  mode      String   @default("separate-profile")
  updatedAt DateTime @default(now()) @updatedAt
}

model MemorySettings {
  id                         String      @id @default("global")
  provider                   String      @default("self-hosted")
  defaultScopeForNewProjects MemoryScope @default(GLOBAL_AND_PROJECT)
  cloudBaseURL               String?
  selfHostedBaseURL          String      @default("http://127.0.0.1:8000")
  updatedAt                  DateTime    @default(now()) @updatedAt
}

enum TaskStatus {
  RUNNING
  WAITING
  STOPPED
  ERROR
  PAUSED
}

enum ScopeType {
  DEFAULT_WORKSPACE
  CUSTOM_FOLDER
  DESKTOP
  FULL_ACCESS
}

enum BackendType {
  E2B
  LOCAL
}

enum BrowserMode {
  SEPARATE_PROFILE
  ACTUAL_CHROME
}

enum MemoryScope {
  GLOBAL_AND_PROJECT
  PROJECT_ONLY
  NONE
}

enum IntegrationConnectorId {
  GMAIL
  SLACK
  NOTION
  GOOGLE_DRIVE
  GITHUB
  GOOGLE_CALENDAR
  CLOUDFLARE
  VERCEL
  LINEAR
  GOOGLE_SHEETS
  GOOGLE_DOCS
  ZAPIER
  OBSIDIAN
}

enum IntegrationConnectionStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
  EXPIRED
  REVOKED
  RATE_LIMITED
  ERROR
}

model TemporalSettings {
  id               String    @id @default("global")
  enabled          Boolean   @default(true)
  address          String    @default("127.0.0.1:7233")
  namespace        String    @default("default")
  taskQueue        String    @default("handle-agent-runs")
  lastHealthStatus String    @default("unknown")
  lastErrorCode    String?
  lastErrorMessage String?
  lastCheckedAt    DateTime?
  updatedAt        DateTime  @default(now()) @updatedAt
}

model NotificationSettings {
  id             String   @id @default("global")
  emailEnabled   Boolean  @default(false)
  emailRecipient String?
  slackEnabled   Boolean  @default(false)
  slackChannelId String?
  webhookEnabled Boolean  @default(false)
  webhookUrl     String?
  eventTypes     Json     @default("[\"TASK_COMPLETED\",\"TASK_FAILED\",\"APPROVAL_NEEDED\",\"CRITIC_FLAGGED\"]")
  updatedAt      DateTime @default(now()) @updatedAt
}

model ProjectNotificationSettings {
  id             String   @id @default(cuid())
  projectId      String   @unique
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inheritGlobal  Boolean  @default(true)
  emailEnabled   Boolean?
  emailRecipient String?
  slackEnabled   Boolean?
  slackChannelId String?
  webhookEnabled Boolean?
  webhookUrl     String?
  eventTypes     Json?
  updatedAt      DateTime @default(now()) @updatedAt
}

model NotificationDelivery {
  id           String                @id @default(cuid())
  userId       String
  projectId    String?
  agentRunId   String?
  eventType    NotificationEventType
  channel      NotificationChannel
  recipient    String
  payload      Json                  @default("{}")
  status       NotificationStatus    @default(PENDING)
  errorCode    String?
  errorMessage String?
  dispatchedAt DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([userId, createdAt])
  @@index([agentRunId])
  @@index([status])
}

enum NotificationEventType {
  TASK_COMPLETED
  TASK_FAILED
  APPROVAL_NEEDED
  CRITIC_FLAGGED
}

enum NotificationChannel {
  EMAIL
  SLACK
  WEBHOOK
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

model NangoSettings {
  id               String    @id @default("global")
  configured       Boolean   @default(false)
  host             String    @default("https://api.nango.dev")
  lastErrorCode    String?
  lastErrorMessage String?
  lastValidatedAt  DateTime?
  secretKeyRef     String?
  updatedAt        DateTime  @default(now()) @updatedAt
}

model IntegrationConnectorSettings {
  id                   String                 @id @default(cuid())
  connectorId          IntegrationConnectorId @unique
  lastErrorCode        String?
  lastErrorMessage     String?
  lastValidatedAt      DateTime?
  nangoIntegrationId   String?
  nangoProviderId      String?
  oauthClientId        String?
  oauthClientSecretRef String?
  redirectUri          String?
  requiredScopes       Json                   @default("[]")
  setupStatus          String                 @default("missing_credentials")
  updatedAt            DateTime               @default(now()) @updatedAt
}

model Integration {
  id                 String                      @id @default(cuid())
  userId             String
  connectorId        IntegrationConnectorId
  nangoIntegrationId String?
  nangoConnectionId  String?
  accountAlias       String
  accountLabel       String?
  status             IntegrationConnectionStatus @default(DISCONNECTED)
  scopes             Json                        @default("[]")
  defaultAccount     Boolean                     @default(false)
  memoryScope        MemoryScope                 @default(NONE)
  metadata           Json                        @default("{}")
  lastUsedAt         DateTime?
  lastHealthCheckAt  DateTime?
  lastErrorCode      String?
  lastErrorMessage   String?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  @@unique([userId, connectorId, accountAlias])
  @@index([userId, connectorId])
  @@index([userId, status])
}

model Conversation {
  id        String     @id @default(cuid())
  projectId String
  title     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages  Message[]
  agentRuns AgentRun[]

  @@index([projectId, updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String
  memoryEnabled  Boolean?
  agentRunId     String?
  providerId     String?
  modelName      String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agentRun       AgentRun?    @relation(fields: [agentRunId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([agentRunId])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

model AgentRun {
  id                     String                  @id @default(cuid())
  conversationId         String
  userId                 String?
  status                 AgentRunStatus          @default(RUNNING)
  goal                   String
  result                 String?
  toolCalls              Json                    @default("[]")
  costUsd                Decimal?                @db.Decimal(10, 4)
  backend                BackendType             @default(E2B)
  providerId             String?
  modelName              String?
  sandboxId              String?
  workflowId             String?                 @unique
  workflowRunId          String?
  workflowStatus         String?
  queuedAt               DateTime?
  lastHeartbeatAt        DateTime?
  lastNotifiedAt         DateTime?
  asyncMode              Boolean                 @default(false)
  startedAt              DateTime                @default(now())
  completedAt            DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  conversation           Conversation            @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  messages               Message[]
  checkpoints            AgentRunCheckpoint[]
  trajectory             AgentRunTrajectory?
  sharedMemoryNamespaces SharedMemoryNamespace[]

  @@index([conversationId, startedAt])
  @@index([status])
  @@index([userId])
  @@index([workflowRunId])
}

enum AgentRunStatus {
  QUEUED
  RUNNING
  WAITING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

model AgentRunTrajectory {
  id             String              @id @default(cuid())
  agentRunId     String              @unique
  agentRun       AgentRun            @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
  steps          Json                @default("[]")
  outcome        TrajectoryOutcome   @default(RUNNING)
  outcomeReason  String?
  outcomeMetrics Json                @default("{}")
  goal           String              @default("")
  goalEmbedding  Bytes?
  templateId     String?
  template       TrajectoryTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  createdAt      DateTime            @default(now())
  completedAt    DateTime?

  @@index([outcome, createdAt])
  @@index([templateId])
}

enum TrajectoryOutcome {
  RUNNING
  SUCCEEDED
  FAILED
  ABANDONED
  CANCELLED
}

model TrajectoryTemplate {
  id             String               @id @default(cuid())
  name           String
  pattern        Json
  goalEmbedding  Bytes
  successRate    Float
  usageCount     Int                  @default(0)
  createdFromIds String[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  trajectories   AgentRunTrajectory[]

  @@index([updatedAt])
}

model AgentRunCheckpoint {
  id         String   @id @default(cuid())
  agentRunId String
  agentRun   AgentRun @relation(fields: [agentRunId], references: [id], onDelete: Cascade)
  stepIndex  Int
  state      Json
  sandboxRef String?
  createdAt  DateTime @default(now())

  @@index([agentRunId, stepIndex])
}

model SharedMemoryNamespace {
  id          String   @id @default(cuid())
  parentRunId String
  parentRun   AgentRun @relation(fields: [parentRunId], references: [id], onDelete: Cascade)
  entries     Json     @default("{}")
  lockedKeys  String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([parentRunId])
}

enum SkillSourceType {
  BUILTIN
  CUSTOM
  IMPORTED
}

enum SkillVisibility {
  BUILTIN
  PERSONAL
  PROJECT
}

enum SkillRunStatus {
  QUEUED
  RUNNING
  WAITING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum SkillRunTrigger {
  MANUAL
  SCHEDULED
  WORKFLOW
  API
  SUGGESTED
}

enum SkillRunStepType {
  PLAN
  TOOL
  APPROVAL
  ARTIFACT
  MEMORY
  BROWSER
  COMPUTER
  CRITIC
  WORKFLOW
  SCHEDULE
  ERROR
}

enum SkillArtifactKind {
  REPORT
  SOURCE_SET
  EMAIL_DRAFTS
  ITINERARY
  CODE_REVIEW
  NOTION_SUMMARY
  EXECUTION_PLAN
  FILE
  BROWSER_SESSION_SUMMARY
  TRACE_SUMMARY
  CUSTOM_JSON
  CUSTOM_MARKDOWN
}

model Skill {
  id                         String          @id @default(cuid())
  slug                       String
  version                    String
  sourceType                 SkillSourceType
  visibility                 SkillVisibility
  ownerUserId                String?
  projectId                  String?
  name                       String
  description                String
  category                   String
  icon                       Json            @default("{}")
  packageMetadata            Json            @default("{}")
  packagePath                String?
  skillMd                    String
  activationExamples         Json            @default("[]")
  negativeActivationExamples Json            @default("[]")
  inputSlots                 Json            @default("[]")
  requiredIntegrations       String[]        @default([])
  optionalIntegrations       String[]        @default([])
  runtimePolicy              Json            @default("{}")
  toolPolicy                 Json            @default("{}")
  approvalPolicy             Json            @default("{}")
  outputArtifactContract     Json            @default("{}")
  sourceCitationPolicy       Json            @default("{}")
  uiTemplate                 String          @default("standard")
  suggestedProvider          String?
  suggestedModel             String?
  evalFixtures               Json            @default("[]")
  reusableResources          Json            @default("[]")
  schedulingConfig           Json            @default("{}")
  customMetadata             Json            @default("{}")
  enabled                    Boolean         @default(true)
  archivedAt                 DateTime?
  createdAt                  DateTime        @default(now())
  updatedAt                  DateTime        @updatedAt
  runs                       SkillRun[]

  @@unique([slug, version, sourceType, ownerUserId, projectId])
  @@index([visibility, projectId])
  @@index([ownerUserId, updatedAt])
}

model SkillRun {
  id                 String          @id @default(cuid())
  skillId            String
  skill              Skill           @relation(fields: [skillId], references: [id], onDelete: Cascade)
  userId             String
  projectId          String?
  conversationId     String?
  agentRunId         String?
  temporalWorkflowId String?
  temporalRunId      String?
  trigger            SkillRunTrigger @default(MANUAL)
  status             SkillRunStatus  @default(QUEUED)
  inputs             Json            @default("{}")
  effectivePolicies  Json            @default("{}")
  providerId         String?
  modelName          String?
  resultSummary      String?
  errorCode          String?
  errorMessage       String?
  costUsd            Decimal?        @db.Decimal(10, 4)
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  steps              SkillRunStep[]
  artifacts          SkillArtifact[]

  @@index([skillId, createdAt])
  @@index([userId, status, createdAt])
  @@index([projectId, createdAt])
  @@index([agentRunId])
}

model SkillRunStep {
  id             String           @id @default(cuid())
  skillRunId     String
  skillRun       SkillRun         @relation(fields: [skillRunId], references: [id], onDelete: Cascade)
  index          Int
  type           SkillRunStepType
  title          String
  status         String
  safeSummary    String
  toolName       String?
  connectorId    String?
  approvalId     String?
  artifactId     String?
  redactedInput  Json             @default("{}")
  redactedOutput Json             @default("{}")
  metadata       Json             @default("{}")
  startedAt      DateTime         @default(now())
  completedAt    DateTime?

  @@unique([skillRunId, index])
  @@index([skillRunId, type])
}

model SkillArtifact {
  id             String            @id @default(cuid())
  skillRunId     String
  skillRun       SkillRun          @relation(fields: [skillRunId], references: [id], onDelete: Cascade)
  kind           SkillArtifactKind
  title          String
  mimeType       String
  inlineContent  String?
  contentRef     String?
  metadata       Json              @default("{}")
  citations      Json              @default("[]")
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([skillRunId, kind])
}

model ApprovalRequest {
  id          String    @id @default(cuid())
  taskId      String
  type        String
  payload     Json
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  respondedAt DateTime?

  @@index([taskId, status])
}
